namespace MyMcpServer {
  type CommonContext = {
    currentTimestamp: datetime,
    ipaddr: ipaddr
  };

  type alert_toolInput = {
    alert?: {
      proj0: MyMcpServer::Null,
      proj1: MyMcpServer::alert_tool::Input::alert::Proj1
    }
  };

  entity McpServer;

  entity Null;

  entity User = {
    id: String,
    username: String
  };

  action "alert_tool" in [Action::"call_tool"] appliesTo {
    principal: [User],
    resource: [McpServer],
    context: {
      input: alert_toolInput,
      session: CommonContext
    }
  };

  action "call_tool";
}

namespace MyMcpServer::alert_tool::Input::alert::Proj1::activeOn {
  entity Proj1 = {
